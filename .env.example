# AlphaScout Backend Configuration
# Copy to .env and fill in your keys

# API authentication (clients must send X-API-Key header)
ALPHASCOUT_API_KEY=your-api-key-here

# Data API keys
FMP_API_KEY=your-fmp-api-key
FRED_API_KEY=your-fred-api-key

# Anthropic (for backtest analysis reports)
ANTHROPIC_API_KEY=your-anthropic-key

# Paths (defaults work inside Docker — override for local dev)
# DB_PATH=/app/data/alphascout.db
# DATA_DIR=/app/data
# WORKSPACE=/app
